{
  "name": "cognitive-typescript-parent",
  "private": true,
  "version": "0.2.2",
  "description": "Cognitive Complexity metrics for TypeScript",
  "license": "Apache-2.0",
  "author": "Fabian Barney (https://github.com/fabian-barney)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fabian-barney/cognitive-typescript.git"
  },
  "homepage": "https://github.com/fabian-barney/cognitive-typescript",
  "bugs": {
    "url": "https://github.com/fabian-barney/cognitive-typescript/issues"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "npm@11.15.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/core packages/cli packages/vitest packages/jest",
    "cognitive-typescript-check": "node ./scripts/run-cognitive-typescript-gate.mjs packages",
    "crap-typescript-check": "vitest run --config vitest.crap.config.ts",
    "lint": "eslint . --max-warnings=0",
    "format:check": "prettier --check \"package*.json\" \"tsconfig*.json\" \"*.mjs\" \"*.ts\" \"packages/**/package.json\" \"packages/**/*.ts\" \"scripts/**/*.mjs\"",
    "format:write": "prettier --write \"package*.json\" \"tsconfig*.json\" \"*.mjs\" \"*.ts\" \"packages/**/package.json\" \"packages/**/*.ts\" \"scripts/**/*.mjs\"",
    "test": "vitest run --coverage.enabled true",
    "pack": "npm pack --workspaces",
    "render-release-notes": "node ./scripts/render-release-notes.mjs",
    "verify-release-version": "node ./scripts/verify-release-version.mjs"
  },
  "devDependencies": {
    "@barney-media/crap-typescript-vitest": "^0.4.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
